# ─── FlowMind environment ────────────────────────────────────────────────────
# Copy to .env (gitignored) for local dev. On Railway, set these via
# `railway variables --set NAME=VALUE` or the dashboard.
# =============================================================================

# Required — server
PORT=8080                                                # injected by Railway in prod
DATABASE_URL=postgres://user:pass@host:5432/flowmind     # set by Railway Postgres addon in prod
AUTH_JWT_SECRET=replace-with-a-long-random-string-32+chars

# LLM (provider-agnostic, OpenAI-compatible endpoint)
# Default = Google Gemini 2.5 Flash via the OpenAI-compat endpoint.
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash-lite
# Free-tier daily quotas:
#   gemini-2.5-flash         = 250 RPD (hit fast on insight-mode)
#   gemini-2.5-flash-lite    = 1000 RPD (recommended default)
#   gemini-2.5-pro           = 100 RPD (highest quality, lowest cap)

# Transcription (Deepgram) — required for the Pro live STT path
DEEPGRAM_API_KEY=

# Web research (Tavily) — required for the auto-research insight feature
TAVILY_API_KEY=

# Public URL — used to build Stripe redirect URLs and similar.
# On Railway this is filled automatically from RAILWAY_PUBLIC_DOMAIN; set
# PUBLIC_BASE_URL explicitly if you map a custom domain.
# PUBLIC_BASE_URL=https://flowmind.yourdomain.com

# Optional — Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional — Stripe (direct, no Replit connector)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional — SMTP for magic-code email login
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
